# Host machine port mappings
FRONTEND_PORT=9090
# Host port published for the backend API.
BACKEND_PORT=9000

# Backend reliability and resource controls
LOG_LEVEL=INFO
JOB_WORKERS=1
MAX_PENDING_JOBS=4
MAX_UPLOAD_BYTES=20971520
MAX_BRIGHTNESS_MAP_BYTES=20971520
MAX_BRIGHTNESS_MAP_PIXELS=16777216
MIN_DRAW_DARKNESS=0.025
MAX_HATCH_PATHS=50000
MAX_TOOLPATH_POINTS=500000
MAX_RETAINED_RESULTS=4
JOB_TTL_SECONDS=1800
CONVERTER_TRANSFER_TTL_SECONDS=900
INKSCAPE_TRACE_TIMEOUT_SECONDS=120
MAX_CONVERTER_TRANSFERS=12
NETWORK_DELIVERY_ENABLED=true
NETWORK_DELIVERY_TIMEOUT_SECONDS=30
MAX_NETWORK_GCODE_BYTES=10485760

# auto uses CUDA when the GPU image/runtime is available, otherwise NumPy CPU
ACCELERATION_BACKEND=auto
COMPOSE_FILE=compose.yml:compose.gpl.yml
